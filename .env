# API
API_HOST=0.0.0.0
API_PORT=8000

# Model paths (base directory for per-symbol models)
MODELS_BASE_DIR=models

# Data
DATA_DIR=data/clean
YFINANCE_PERIOD=60d

AUTO_TRADER_INTERVAL_SEC=60

# Trade probability threshold (only offer trade when prob >= this)
TRADE_PROB_THRESHOLD=0.005

# Backtest: use SMC filter (true) or model-only (false, default)
BACKTEST_USE_SMC=false

# Backtest: apply market hours filter (true) or include all bars (false, default)
BACKTEST_USE_MARKET_HOURS=false

# SMC filter: for live trading; backtest uses BACKTEST_USE_SMC
SMC_REQUIRE_ORDER_BLOCK=false

# SMC: bars to scan for order block / FVG / liquidity sweep
SMC_OB_LOOKBACK_BARS=30

# SMC: require Fair Value Gap before entry
SMC_REQUIRE_FVG=false

# SMC: require liquidity sweep before entry
SMC_REQUIRE_LIQUIDITY_SWEEP=false

# SMC: ATR multiplier for demand/supply zone width
SMC_ZONE_WIDTH_ATR=0.6

# SMC: minimum FVG size in ATR (filter noise)
SMC_FVG_MIN_SIZE_ATR=0.3

# SMC: minimum order block strength (0 = off)
SMC_MIN_OB_STRENGTH=0.0

# SMC: require price inside zone for entry
SMC_REQUIRE_PRICE_IN_ZONE=false

# SMC: when true, pass if ANY of OB/FVG/sweep present (OR logic); when false, all required (AND)
SMC_REQUIRE_ANY=true


# Market hours: disable to bypass (always allow trading)
MARKET_HOURS_ENABLED=true

# MT5 for live data (Windows only)
MT5_ENABLED=true

# MAX_SPREAD_POINTS=25